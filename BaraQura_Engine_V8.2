import os
import sys
import time

class SecurityGuardian:
    def __init__(self, master_key_hash):
        self.master_key = master_key_hash
        self.failed_attempts = 0
        self.max_attempts = 3

    def verify_access(self, input_key):
        if input_key == self.master_key:
            print("🔓 Access Granted. System Online.")
            self.failed_attempts = 0 # রিসেট
            return True
        else:
            self.failed_attempts += 1
            print(f"⚠️ Warning: Invalid Master Key! Attempt {self.failed_attempts}/{self.max_attempts}")
            
            if self.failed_attempts >= self.max_attempts:
                self.trigger_lockdown()
            return False

    def trigger_lockdown(self):
        print("🚨 CRITICAL: Unauthorized Access Detected! Initiating Lockdown...")
        
        # ১. গুরুত্বপূর্ণ কনফিগ ফাইল রিনেম বা হাইড করা (Self-Preservation)
        if os.path.exists("v82_config.json"):
            os.rename("v82_config.json", ".hidden_vault_locked")
            
        # ২. টেলিগ্রামে অ্যালার্ট পাঠানো (যদি আপনার বট কানেক্টেড থাকে)
        # send_telegram_alert("SOS: Someone is trying to breach v8.2!")

        # ৩. পিসি শাটডাউন কমান্ড (Windows এর জন্য)
        time.sleep(2)
        print("💻 System Shutting Down to Protect Data...")
        os.system("shutdown /s /t 5") 
        sys.exit()

# --- Implementation ---
# আপনার v8.2 এর মাস্টার হ্যাশ এখানে থাকবে
GUARDIAN = SecurityGuardian("your_secure_hash_here")

